@model AlbumDto
@{
    ViewData["Title"] = "Álbum";
}
<div class="card shadow-sm border-0 mb-4">
    <div class="row g-0">
        <div class="col-md-4">
            <img src="@Model.PortadaUrl" class="img-fluid h-100 object-fit-cover rounded-start" alt="@Model.Titulo" />
        </div>
        <div class="col-md-8">
            <div class="card-body p-4">
                <h2>@Model.Titulo</h2>
                <p><strong>Artista:</strong> <a asp-controller="Artistas" asp-action="Details" asp-route-id="@Model.IdArtista">@Model.Artista</a></p>
                <p><strong>Año:</strong> @Model.Anio</p>
                <p class="text-muted">Canciones del álbum</p>
                <ul class="list-group list-group-flush">
                    @foreach (var song in Model.Canciones)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@song.Nombre</span>
                            <button type="button" class="btn btn-success btn-sm"
                                    onclick="playSong(@song.IdCancion, '@song.Nombre'.replace(/'/g, '\\''), '@song.Artista'.replace(/'/g, '\\''), '@song.AudioUrl', '@song.ImagenUrl')">
                                Reproducir
                            </button>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
