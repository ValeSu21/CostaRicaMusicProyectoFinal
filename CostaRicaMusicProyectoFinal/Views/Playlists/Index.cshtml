@model List<PlaylistDto>
@{
    ViewData["Title"] = "Playlists";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Mis playlists</h2>
        <small class="text-muted">CRUD básico en memoria para el avance.</small>
    </div>
    <a asp-action="Create" class="btn btn-dark">Nueva playlist</a>
</div>

@foreach (var playlist in Model)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <h4>@playlist.Nombre</h4>
                    <p class="text-muted mb-2">@playlist.Descripcion</p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@playlist.IdPlaylist" class="btn btn-outline-dark btn-sm">Editar</a>
                    <form method="post" asp-action="Delete">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@playlist.IdPlaylist" />
                        <button class="btn btn-outline-danger btn-sm">Eliminar</button>
                    </form>
                </div>
            </div>

            @if (playlist.Canciones.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Canción</th>
                                <th>Artista</th>
                                <th>Álbum</th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var song in playlist.Canciones)
                        {
                            <tr>
                                <td>@song.Nombre</td>
                                <td>@song.Artista</td>
                                <td>@song.Album</td>
                                <td>
                                    <button type="button" class="btn btn-success btn-sm"
                                            onclick="playSong(@song.IdCancion, '@song.Nombre'.replace(/'/g, '\\''), '@song.Artista'.replace(/'/g, '\\''), '@song.AudioUrl', '@song.ImagenUrl')">
                                        Reproducir
                                    </button>
                                </td>
                                <td>
                                    <form method="post" asp-action="RemoveSong">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="playlistId" value="@playlist.IdPlaylist" />
                                        <input type="hidden" name="songId" value="@song.IdCancion" />
                                        <button class="btn btn-outline-danger btn-sm">Quitar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Esta playlist todavía no tiene canciones.</p>
            }
        </div>
    </div>
}
